{
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/badkamerrenovatie-antwerpen/?", "dest": "/badkamerrenovatie-antwerpen.html" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
